<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".CleanCadApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CleanCAD">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.ViewerActivity"
            android:label="@string/app_name"
            android:exported="true">
            <!-- 1) .dwg MIME 을 제대로 지정하는 앱/파일매니저용 (표준 DWG MIME 변종 망라) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/acad" />
                <data android:mimeType="application/x-dwg" />
                <data android:mimeType="application/dwg" />
                <data android:mimeType="image/vnd.dwg" />
                <data android:mimeType="image/x-dwg" />
                <data android:mimeType="drawing/dwg" />
                <data android:mimeType="application/x-autocad" />
            </intent-filter>
            <!-- 2) 카카오톡 등은 .dwg 를 일반 바이너리(application/octet-stream)로 넘긴다.
                 content:// 에는 pathPattern 이 안 걸리므로 octet-stream 을 폭넓게 받되,
                 실제 DWG 여부는 ViewerActivity 가 매직헤더("AC1x")/확장자로 검증해
                 .dwg 가 아니면 안내 후 종료한다 (DrawingViewModel.isLikelyDwg). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
            <!-- 3) 공유(SEND) 받기 — 카톡 등이 미리보기 '열기' 대신 시스템 공유시트로 보낼 때.
                 공유시트는 시스템이 띄워 패키지 가시성 제한을 안 받으므로(안드 11+ 에서도)
                 '공유 → CleanCAD' 경로가 동작한다. URI 는 EXTRA_STREAM 으로 들어온다. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/acad" />
                <data android:mimeType="application/x-dwg" />
                <data android:mimeType="application/dwg" />
                <data android:mimeType="image/vnd.dwg" />
                <data android:mimeType="image/x-dwg" />
                <data android:mimeType="drawing/dwg" />
                <data android:mimeType="application/x-autocad" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SettingsActivity"
            android:label="@string/settings"
            android:exported="false" />

        <activity
            android:name=".ui.AboutActivity"
            android:label="@string/about"
            android:exported="false" />

    </application>

</manifest>
